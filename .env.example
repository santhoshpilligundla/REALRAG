# Copy to .env and adjust if needed.

# pgserver writes its data here (gitignored). The DSN is resolved at runtime
# from pgserver — there is no fixed port.
PG_DATA_DIR=./storage/pg-data
PG_DB_NAME=realrag

# LLM provider keys — required only when ingestion / chat is wired up (Day 2+).
# Phase 1 (config screen + repo registration) does not need these.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

EMBEDDING_MODEL=openai:text-embedding-3-large
DEFAULT_CHAT_PROVIDER=anthropic
DEFAULT_ANTHROPIC_MODEL=claude-haiku-4-5
REASONING_ANTHROPIC_MODEL=claude-opus-4-7

LOG_LEVEL=INFO
